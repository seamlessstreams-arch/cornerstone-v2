# ══════════════════════════════════════════════════════════════════════════════
# CARA OS — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Legacy note: variables previously used the ARIA_* prefix. The platform reads
# CARA_* first and falls back to ARIA_*, so existing deployments keep working.
# Prefer CARA_* for new configuration.
# ══════════════════════════════════════════════════════════════════════════════

# ── AI Provider (Cara Intelligence) ──────────────────────────────────────────
# Choose one provider: "anthropic" (recommended) or "openai"
AI_PROVIDER=anthropic
CARA_AI_ENABLED=true
CARA_MODEL=claude-sonnet-4-20250514
# Optional overrides (legacy ARIA_* equivalents still honoured):
# CARA_PROVIDER=anthropic
# CARA_TEXT_MODEL=
# CARA_TEMPERATURE=
# CARA_MAX_TOKENS=

# Anthropic (recommended)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# OpenAI (alternative — also enables voice transcription)
# OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ── Supabase (Database & Auth) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Set to "true" to enable Supabase persistence (audit logs, approvals, etc.)
# When "false", the platform uses an in-memory store for demo/development.
NEXT_PUBLIC_SUPABASE_ENABLED=false

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cara OS
NEXT_PUBLIC_APP_SHORT_NAME=Cara
NEXT_PUBLIC_AI_NAME=Cara Intelligence
NEXT_PUBLIC_ASSISTANT_NAME=Cara Assistant

# ── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CARA_ENABLED=true
NEXT_PUBLIC_DEMO_MODE=true
